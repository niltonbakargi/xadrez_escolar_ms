# Copie este arquivo para .env e preencha os valores

# Segurança
SECRET_KEY=troque-por-uma-chave-segura-de-32-caracteres
DEBUG=False

# Banco de dados (MySQL via XAMPP)
DATABASE_URL=mysql+aiomysql://root:@localhost:3306/xadrez
# Se você definiu senha no MySQL do XAMPP:
# DATABASE_URL=mysql+aiomysql://root:SUA_SENHA@localhost:3306/xadrez

# lichess
LICHESS_API_TOKEN=seu-token-lichess-aqui

# Stockfish
STOCKFISH_PATH=./stockfish/engines/stockfish
STOCKFISH_DEPTH=18

# Redis (filas de análise)
REDIS_URL=redis://localhost:6379/0

# IA (Fase 2 — opcional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
